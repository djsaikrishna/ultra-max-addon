+function addCollection(){
+  v2Collections.push({
+    title: 'New Collection ' + (v2Collections.length + 1),
+    collapsed: false,
+    folders: [
+      applyFolderMedia({
+        title: 'New Folder',
+        rows: []
+      })
+    ]
+  });
+  renderCollections();
+}
