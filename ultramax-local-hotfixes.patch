+function getCatalogSourceType(id){
+  if(!id) return 'movie';
+  if(id.includes('_series')) return 'series';
+  if(id.includes('_tv_collection')) return 'series';
+  if(id === 'airing_series' || id === 'ontheair_series') return 'series';
+  if(id === 'top_series' || id === 'popular_series' || id === 'trending_series') return 'series';
+  if(id === 'search_series') return 'series';
+  return 'movie';
+}
+
+function getNuvioViewMode(){
+  const el = document.getElementById('nuvioViewMode');
+  return el && el.value ? el.value : 'TABBED_GRID';
+}
+
+function safeNuvioId(prefix, value, fallback){
+  const base = String(value || fallback || '')
+    .toLowerCase()
+    .replace(/[^a-z0-9]+/g, '-')
+    .replace(/^-+|-+$/g, '')
+    .slice(0, 40);
+
+  return prefix + '-' + (base || Math.random().toString(36).slice(2, 9));
+}
+
+function buildCollectionsExport(){
+  return (v2Collections || []).map(function(coll, collIndex){
+    const collTitle = coll.title || 'Collection';
+
+    return {
+      id: coll.id || safeNuvioId('collection', collTitle, 'collection-' + collIndex),
+      title: collTitle,
+      folders: (coll.folders || []).map(function(folder, folderIndex){
+        const folderTitle = folder.title || 'Folder';
+
+        return {
+          id: folder.id || safeNuvioId('folder', collTitle + '-' + folderTitle, 'folder-' + collIndex + '-' + folderIndex),
+          title: folderTitle,
+          hideTitle: false,
+          tileShape: folder.tileShape || 'LANDSCAPE',
+          focusGifUrl: folder.focusGifUrl || '',
+          coverImageUrl: folder.coverImageUrl || '',
+          catalogSources: (folder.rows || []).map(function(id){
+            const sourceType = getCatalogSourceType(id);
+            return {
+              id: safeNuvioId('source', id, id),
+              addonId: getGeneratedAddonId(),
+              catalogId: id,
+              type: sourceType,
+              showInHome: false
+            };
+          }),
+          focusGifEnabled: !!folder.focusGifEnabled
+        };
+      }),
+      pinToTop: true,
+      viewMode: getNuvioViewMode(),
+      showAllTab: true,
+      focusGlowEnabled: true
+    };
+  });
+}
