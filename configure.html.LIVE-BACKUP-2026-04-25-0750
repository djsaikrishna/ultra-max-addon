function getCollectionMatches(key){
  const preset = COLLECTION_PRESETS[key];
  if(!preset) return [];
  return preset.ids.filter(function(id){ return selected.has(id); });
}

function refreshCollectionPresetButtons(){
  document.querySelectorAll('.coll-preset-btn').forEach(function(btn){
    const key = btn.dataset.collPreset;
    const matches = getCollectionMatches(key);
    btn.style.display = matches.length ? 'inline-block' : 'none';
    btn.disabled = !matches.length;
    btn.style.opacity = matches.length ? '1' : '0.35';
  });
}

function renderCollectionDrafts(){
