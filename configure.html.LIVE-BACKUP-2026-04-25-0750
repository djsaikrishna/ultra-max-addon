<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ultra MAX — Build Your Addon</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Courier+Prime:wght@400;700&family=Bebas+Neue&display=swap');
  *{box-sizing:border-box;margin:0;padding:0;}
  body{background:#0a0a0a;color:#fff;font-family:'Courier Prime',monospace;min-height:100vh;display:flex;justify-content:center;padding:40px 0;}

  /* FILMSTRIP */
  .filmstrip{display:flex;width:100%;max-width:860px;min-height:100vh;}
  .sprocket{width:52px;background:#111;border-right:3px solid #000;display:flex;flex-direction:column;gap:0;padding:12px 0;flex-shrink:0;}
  .sprocket.right{border-right:none;border-left:3px solid #000;}
  .hole{width:22px;height:16px;background:#000;border-radius:3px;border:1.5px solid #222;margin:6px auto;flex-shrink:0;}
  .cell{flex:1;background:#111;border-left:4px solid #000;border-right:4px solid #000;padding:0 0 60px 0;}
  .cell-header{border-bottom:1px solid #2a2a2a;padding:20px 32px 16px;display:flex;justify-content:space-between;align-items:center;}
  .frame-num{font-size:10px;color:#aaa;letter-spacing:0.1em;}
  h1{font-family:'Bebas Neue',sans-serif;font-size:3rem;letter-spacing:0.08em;text-align:center;padding:28px 32px 6px;color:#fff;}
  .subtitle{text-align:center;color:#ccc;font-size:12px;letter-spacing:0.15em;text-transform:uppercase;padding-bottom:24px;border-bottom:1px solid #1a1a1a;}
  .edit-banner{background:#1a1a1a;border-bottom:1px solid #2a2a2a;padding:12px 32px;font-size:11px;color:#aaa;letter-spacing:0.05em;display:none;}
  .edit-banner.visible{display:block;}

  /* PROGRESS BAR */
  .progress-bar{padding:20px 32px;border-bottom:1px solid #1a1a1a;background:#0d0d0d;}
  .progress-steps{display:flex;align-items:center;gap:0;}
  .progress-step{display:flex;align-items:center;flex:1;}
  .step-circle{width:28px;height:28px;border-radius:50%;border:2px solid #333;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:14px;color:#555;flex-shrink:0;transition:all 0.3s;}
  .step-circle.active{border-color:#fff;color:#fff;}
  .step-circle.done{border-color:#fff;background:#fff;color:#000;}
  .step-label{font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:#555;margin-left:8px;transition:color 0.3s;}
  .step-label.active{color:#bbb;}
  .step-label.done{color:#888;}
  .step-connector{flex:1;height:1px;background:#222;margin:0 8px;transition:background 0.3s;}
  .step-connector.done{background:#555;}

  /* STEPS */
  .wizard-step{display:none;padding:28px 32px;}
  .wizard-step.active{display:block;}
  .section-title{font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:#bbb;margin-bottom:16px;display:flex;align-items:center;gap:10px;}
  .section-title::after{content:'';flex:1;height:1px;background:#444;}

  /* INPUTS */
  .input-row{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:10px;}
  input[type=password],input[type=text],select{background:#0a0a0a;border:1px solid #2a2a2a;color:#fff;font-family:'Courier Prime',monospace;font-size:14px;padding:10px 14px;border-radius:4px;flex:1;min-width:200px;outline:none;transition:border-color 0.2s;width:100%;}
  input:focus,select:focus{border-color:#666;}
  .input-hint{font-size:11px;color:#bbb;margin-top:6px;letter-spacing:0.03em;}
  .field-block{margin-bottom:20px;}
  .field-label{font-size:11px;color:#ccc;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:8px;display:flex;align-items:center;gap:8px;}
  .badge{font-size:9px;padding:2px 6px;border-radius:2px;letter-spacing:0.1em;}
  .badge-required{background:#1a1a1a;border:1px solid #c0392b;color:#e74c3c;}
  .badge-optional{background:#1a1a1a;border:1px solid #333;color:#666;}
  .info-box{margin-top:10px;padding:12px 16px;background:#0f0f0f;border:1px solid #2a2a2a;border-radius:4px;font-size:12px;color:#ccc;line-height:1.6;}
  .info-box a{color:#fff;text-decoration:underline;text-underline-offset:3px;}
  .info-box strong{color:#fff;}
  .collapsible-link{margin-top:10px;font-size:11px;color:#aaa;cursor:pointer;text-decoration:underline;text-underline-offset:3px;display:inline-block;}
  .collapsible-link:hover{color:#fff;}
  .verify-btn{background:transparent;border:1px solid #444;color:#bbb;font-family:"Courier Prime",monospace;font-size:11px;padding:8px 12px;cursor:pointer;border-radius:4px;white-space:nowrap;transition:all 0.15s;flex-shrink:0;}
  .verify-btn:hover{border-color:#999;color:#fff;}
  .verify-result{font-size:11px;margin-top:6px;display:none;}
  .verify-result.ok{display:block;color:#2ecc71;}
  .verify-result.fail{display:block;color:#e74c3c;}
  .collapsible-content{display:none;margin-top:12px;padding:16px;background:#0a0a0a;border:1px solid #2a2a2a;border-radius:4px;font-size:12px;color:#ccc;line-height:1.8;}
  .collapsible-content.open{display:block;}
  .divider{height:1px;background:#1a1a1a;margin:20px 0;}
  .error-msg{color:#e74c3c;font-size:12px;margin-top:8px;display:none;}
  .error-msg.visible{display:block;}

  /* RETURNING USER */
  .returning-toggle{font-size:11px;color:#aaa;cursor:pointer;text-decoration:underline;text-underline-offset:3px;display:inline-block;margin-top:4px;}
  .returning-toggle:hover{color:#fff;}
  .returning-box{display:none;margin-top:12px;}
  .returning-box.open{display:block;}
  .returning-row{display:flex;gap:10px;flex-wrap:wrap;}
  .load-btn{background:transparent;border:1px solid #444;color:#ccc;font-family:'Courier Prime',monospace;font-size:13px;padding:10px 16px;cursor:pointer;border-radius:4px;white-space:nowrap;transition:all 0.15s;}
  .load-btn:hover{border-color:#999;color:#fff;}

  /* NAV BUTTONS */
  .nav-btns{display:flex;justify-content:space-between;align-items:center;margin-top:32px;padding-top:20px;border-top:1px solid #1a1a1a;}
  .nav-btn{background:transparent;border:1px solid #444;color:#bbb;font-family:'Courier Prime',monospace;font-size:13px;padding:10px 24px;cursor:pointer;border-radius:4px;transition:all 0.15s;letter-spacing:0.05em;}
  .nav-btn:hover{border-color:#999;color:#fff;}
  .nav-btn.primary{background:#fff;color:#000;border-color:#fff;font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:0.1em;padding:10px 32px;}
  .nav-btn.primary:hover{opacity:0.85;}
  .nav-btn:disabled{opacity:0.3;cursor:not-allowed;}

  /* PRESETS */
  .presets-grid{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px;}
  .preset-btn{background:transparent;border:1px solid #333;color:#ccc;font-family:'Courier Prime',monospace;font-size:12px;padding:10px 18px;border-radius:3px;cursor:pointer;transition:all 0.15s;text-align:left;flex:1;min-width:150px;}
  .preset-btn:hover{border-color:#777;color:#fff;}
  .preset-btn .preset-name{display:block;font-weight:700;font-size:13px;color:#fff;margin-bottom:3px;}
  .preset-btn .preset-desc{display:block;font-size:10px;color:#888;letter-spacing:0.05em;line-height:1.4;}
  .preset-btn.active{border-color:#fff;background:#1a1a1a;}

  /* CATALOG CONTROLS */
  .catalog-controls{display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-bottom:20px;}
  .search-box{flex:1;min-width:180px;background:#0a0a0a;border:1px solid #2a2a2a;color:#fff;font-family:'Courier Prime',monospace;font-size:13px;padding:8px 14px;border-radius:4px;outline:none;transition:border-color 0.2s;width:auto;}
  .search-box:focus{border-color:#666;}
  .search-box::placeholder{color:#777;}
  .global-btn{background:transparent;border:1px solid #444;color:#bbb;font-family:'Courier Prime',monospace;font-size:11px;padding:8px 14px;border-radius:3px;cursor:pointer;letter-spacing:0.05em;transition:all 0.15s;white-space:nowrap;}
  .global-btn:hover{border-color:#999;color:#fff;}

  /* CATEGORIES */
  .category{margin-bottom:20px;padding-bottom:20px;border-bottom:1px solid #1a1a1a;}
  .category:last-child{border-bottom:none;}
  .category.hidden{display:none;}
  .cat-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:0;cursor:pointer;padding:4px 0;user-select:none;}
  .cat-header:hover .cat-title{color:#fff;}
  .cat-chevron{font-size:10px;color:#555;transition:transform 0.2s;margin-left:8px;flex-shrink:0;}
  .cat-chevron.open{transform:rotate(180deg);}
  .pills-wrap{display:none;padding-top:12px;}
  .pills-wrap.open{display:block;}
  .cat-title{font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#bbb;display:flex;align-items:center;gap:8px;}
  .cat-icon{font-size:13px;}
  .cat-count{font-size:10px;color:#888;margin-left:4px;}
  .select-all{font-size:10px;color:#999;cursor:pointer;letter-spacing:0.1em;text-transform:uppercase;flex-shrink:0;}
  .select-all:hover{color:#fff;}
  .pills{display:flex;flex-wrap:wrap;gap:8px;}
  .pill{background:transparent;border:1px solid #333;color:#bbb;font-family:'Courier Prime',monospace;font-size:12px;padding:5px 12px;border-radius:3px;cursor:pointer;transition:all 0.15s;user-select:none;letter-spacing:0.03em;}
  .pill:hover{border-color:#888;color:#fff;}
  .pill.selected{background:#fff;border-color:#fff;color:#000;font-weight:700;}
  .pill.hidden{display:none;}

  /* COUNTER BAR */
  .counter-bar{position:sticky;bottom:0;background:#111;border-top:1px solid #2a2a2a;padding:14px 32px;display:flex;align-items:center;justify-content:space-between;z-index:10;}
  .count-display{font-size:11px;color:#bbb;letter-spacing:0.1em;}
  .count-num{color:#fff;font-size:20px;font-family:'Bebas Neue',sans-serif;}
  .next-btn{background:#fff;color:#000;border:none;font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:0.1em;padding:10px 28px;cursor:pointer;border-radius:3px;transition:opacity 0.15s;}
  .next-btn:hover{opacity:0.85;}
  .next-btn:disabled{opacity:0.3;cursor:not-allowed;}

  /* RESULT */
  .result-section{margin-top:24px;padding:20px;background:#0a0a0a;border:1px solid #2a2a2a;border-radius:6px;}
  .result-label{font-size:10px;color:#bbb;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:10px;}
  .url-display{font-size:12px;color:#fff;word-break:break-all;margin-bottom:14px;padding:10px;background:#0f0f0f;border:1px solid #222;border-radius:4px;}
  .result-btns{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px;}
  .rbtn{padding:10px 22px;border-radius:4px;font-family:'Courier Prime',monospace;font-size:13px;cursor:pointer;border:1px solid #444;background:transparent;color:#ccc;transition:all 0.15s;text-decoration:none;display:inline-block;}
  .rbtn:hover{border-color:#999;color:#fff;}
  .rbtn.primary{background:#fff;color:#000;border-color:#fff;font-weight:700;}
  .rbtn.primary:hover{opacity:0.85;}
  .token-save{padding:12px;background:#0f0f0f;border:1px solid #1a1a1a;border-radius:4px;font-size:11px;color:#888;line-height:1.8;}
  .token-save span{color:#ccc;}

  .loading{text-align:center;padding:20px;color:#888;font-size:12px;letter-spacing:0.1em;display:none;}
  .loading.visible{display:block;}

  ::-webkit-scrollbar{width:4px;}
  ::-webkit-scrollbar-track{background:#0a0a0a;}
  ::-webkit-scrollbar-thumb{background:#333;border-radius:2px;}
</style>
</head>
<body>
<div class="filmstrip">
  <div class="sprocket" id="s1"></div>
  <div class="cell">
    <div class="cell-header">
      <span class="frame-num">ULTRA MAX — CONFIGURE</span>
      <span class="frame-num">35mm</span>
    </div>
    <div class="edit-banner" id="editBanner">Editing existing configuration. Enter your password to save changes.</div>
    <h1>Build Your Addon</h1>
    <p class="subtitle">Personalise your Stremio / Nuvio home screen</p>

    <!-- PROGRESS -->
    <div class="progress-bar">
      <div class="progress-steps">
        <div class="progress-step">
          <div class="step-circle active" id="circle-1">1</div>
          <span class="step-label active" id="label-1">Setup</span>
        </div>
        <div class="step-connector" id="conn-1"></div>
        <div class="progress-step">
          <div class="step-circle" id="circle-2">2</div>
          <span class="step-label" id="label-2">Home Rows</span>
        </div>
        <div class="step-connector" id="conn-2"></div>
        <div class="progress-step">
          <div class="step-circle" id="circle-3">3</div>
          <span class="step-label" id="label-3">Collections</span>
        </div>
        <div class="step-connector" id="conn-3"></div>
        <div class="progress-step">
          <div class="step-circle" id="circle-4">4</div>
          <span class="step-label" id="label-4">Finalize</span>
        </div>

      </div>
    </div>

    <!-- STEP 1: SETUP -->
    <div class="wizard-step active" id="step-1">

      <!-- Password -->
      <div class="field-block">
        <div class="section-title">Account</div>
        <div class="input-row">
          <input type="password" id="password" placeholder="Password" autocomplete="new-password" />
          <input type="password" id="confirmPassword" placeholder="Confirm Password" autocomplete="new-password" />
        </div>
        <div class="error-msg" id="passError">Passwords do not match</div>
      </div>

      <div class="divider"></div>

      <!-- MDBList -->
      <div class="field-block">
        <div class="field-label">&#128273; MDBList API Key <span class="badge badge-required">REQUIRED</span></div>
        <div style="display:flex;gap:8px;align-items:center;">
  <input type="text" id="mdblistKey" placeholder="Paste your free MDBList API key here" style="flex:1;" />
  <button type="button" class="verify-btn" onclick="verifyKey('mdblist')" id="verify-mdblist">Check</button>
</div>
<div class="verify-result" id="result-mdblist"></div>
        <div class="info-box" style="margin-top:10px;">
          <strong>A free MDBList API key is required.</strong><br>
          Powers all curated lists, latest releases and trending charts. Free, takes 30 seconds.<br><br>
          <a href="https://mdblist.com/?ref=ultramax" target="_blank" rel="noopener">Get your free key here &rarr;</a>
        </div>
        <span class="collapsible-link" onclick="toggleCollapsible('guideBox', this)" id="guideToggle">&#9432; How do I get a key?</span>
        <div class="collapsible-content" id="guideBox">
          <strong style="color:#fff;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;">How to get your free MDBList API key</strong><br><br>
          <span style="color:#888;">Step 1 —</span> Go to <a href="https://mdblist.com/register" target="_blank" style="color:#fff;">mdblist.com/register</a> and create a free account.<br><br>
          <span style="color:#888;">Step 2 —</span> Check your email and confirm your account.<br><br>
          <span style="color:#888;">Step 3 —</span> Once logged in, go to <a href="https://mdblist.com/api/" target="_blank" style="color:#fff;">mdblist.com/api</a><br><br>
          <span style="color:#888;">Step 4 —</span> Your API key is shown on that page. Copy it.<br><br>
          <span style="color:#888;">Step 5 —</span> Paste it into the box above and you're done!<br><br>
          <span style="color:#666;font-size:11px;">The free tier gives you 1,000 requests per day — more than enough for personal use.</span>
        </div>
      </div>

      <div class="divider"></div>

      <!-- Language -->
      <div class="field-block">
        <div class="field-label">&#127760; Metadata Language</div>
        <select id="language">
          <option value="en-US">🇬🇧 English</option>
          <option value="es-ES">🇪🇸 Spanish</option>
          <option value="es-MX">🇲🇽 Spanish (Latin American)</option>
          <option value="fr-FR">🇫🇷 French</option>
          <option value="de-DE">🇩🇪 German</option>
          <option value="it-IT">🇮🇹 Italian</option>
          <option value="pt-BR">🇧🇷 Portuguese</option>
          <option value="nl-NL">🇳🇱 Dutch</option>
          <option value="pl-PL">🇵🇱 Polish</option>
          <option value="tr-TR">🇹🇷 Turkish</option>
          <option value="ar-SA">🇸🇦 Arabic</option>
        </select>
        <div class="input-hint">Titles and descriptions will appear in your chosen language.</div>
      </div>

      <div class="divider"></div>

      <!-- RPDB -->
      <div class="field-block">
        <div class="field-label">&#127909; RPDB API Key <span class="badge badge-optional">OPTIONAL</span></div>
        <div style="display:flex;gap:8px;align-items:center;">
  <input type="text" id="rpdbKey" placeholder="Your RPDB API key for rated posters" style="flex:1;" />
  <button type="button" class="verify-btn" onclick="verifyKey('rpdb')" id="verify-rpdb">Check</button>
</div>
<div class="verify-result" id="result-rpdb"></div>
        <div class="info-box" style="margin-top:10px;">
          <strong>Get rated posters with RPDB.</strong><br>
          Adds rating overlays to all movie and series posters. Free tier available.<br><br>
          <a href="https://ratingposterdb.com" target="_blank" rel="noopener">Get your RPDB key here &rarr;</a>
        </div>
      </div>

      <div class="divider"></div>

      <!-- TOP Posters -->
      <div class="field-block">
        <div class="field-label">&#11088; TOP Posters API Key <span class="badge badge-optional">OPTIONAL</span></div>
        <div style="display:flex;gap:8px;align-items:center;">
  <input type="text" id="tpKey" placeholder="Your TOP Posters API key" style="flex:1;" />
  <button type="button" class="verify-btn" onclick="verifyKey('tp')" id="verify-tp">Check</button>
</div>
<div class="verify-result" id="result-tp"></div>
        <div class="info-box" style="margin-top:10px;">
          <strong>Get enhanced posters with TOP Posters.</strong><br>
          Multiple rating badges, trend indicators and episode thumbnails. Free tier available with 10,000 requests/month. Takes priority over RPDB if both are set.<br><br>
          <a href="https://api.top-streaming.stream" target="_blank" rel="noopener">Get your TOP Posters key here &rarr;</a>
        </div>
      </div>

      <!-- Trakt Username -->
      <div class="field-block">
        <div class="field-label">&#127909; Trakt Username <span class="badge badge-optional">OPTIONAL</span></div>
        <div style="display:flex;gap:8px;align-items:center;">
          <input type="text" id="traktUser" placeholder="Your Trakt.tv username" style="flex:1;" />
        </div>
        <div class="info-box" style="margin-top:10px;">
          <strong>Connect your Trakt account.</strong><br>
          Adds your Favorites, Watchlist, and Collection as personal catalogs. Make sure your Trakt profile is set to Public.<br><br>
          <a href="https://trakt.tv/users/settings" target="_blank" rel="noopener">Trakt Settings &rarr;</a>
        </div>
      </div>

      <!-- Hide Unreleased -->
      <div class="field-block">
        <div style="display:flex;align-items:center;gap:10px;">
          <input type="checkbox" id="excludeUnreleased" style="width:18px;height:18px;cursor:pointer;" />
          <label for="excludeUnreleased" style="cursor:pointer;user-select:none;font-weight:600;">&#128683; Hide unreleased titles</label>
        </div>
        <div class="info-box" style="margin-top:10px;">
          Filters out movies and series that haven't released yet. Excludes "Coming Soon" titles from all catalogs.
        </div>
      </div>

      <!-- Age Rating -->
      <div class="field-block">
        <div class="field-label">&#128101; Max Age Rating <span class="badge badge-optional">OPTIONAL</span></div>
        <div style="display:flex;gap:8px;align-items:center;">
          <select id="maxRating" style="flex:1;padding:10px;background:#0d0d0d;color:#fff;border:1px solid #2a2a2a;border-radius:6px;">
            <option value="">No restriction</option>
            <option value="G">G - General Audiences</option>
            <option value="PG">PG - Parental Guidance</option>
            <option value="PG-13">PG-13 - Parents Strongly Cautioned</option>
            <option value="R">R - Restricted</option>
            <option value="NC-17">NC-17 - Adults Only</option>
          </select>
        </div>
        <div class="info-box" style="margin-top:10px;">
          Hide all movies above this rating. Uses US certifications. Great for kid-safe setups.
        </div>
      </div>

      <div class="divider"></div>

      <!-- Returning user -->
      <div class="field-block">
        <span class="returning-toggle" onclick="toggleReturning()">&#8617; Returning user? Load your existing config</span>
        <div class="returning-box" id="returningBox">
          <div class="returning-row" style="margin-top:12px;">
            <input type="text" id="tokenInput" placeholder="Enter your config token (e.g. ABC123)" style="flex:1;min-width:160px;" />
            <button class="load-btn" onclick="loadConfig()">Load Config</button>
          </div>
        </div>
      </div>

      <div class="nav-btns">
        <span></span>
        <button class="nav-btn primary" onclick="goToStep2()">Next — Pick Catalogs &rarr;</button>
      </div>
    </div>

    <!-- STEP 2: CATALOGS -->
    <div class="wizard-step" id="step-2">

      <!-- Presets -->
      <div class="section-title">&#9889; Quick Start</div>
      <div class="presets-grid">
        <button class="preset-btn" onclick="applyPreset('casual', event)">
          <span class="preset-name">&#127780; Casual Viewer</span>
          <span class="preset-desc">Trending, popular & key genres</span>
        </button>
        <button class="preset-btn" onclick="applyPreset('binge', event)">
          <span class="preset-name">&#127871; Binge Watcher</span>
          <span class="preset-desc">Streaming services, genres & lists</span>
        </button>
        <button class="preset-btn" onclick="applyPreset('everything', event)">
          <span class="preset-name">&#128293; Everything</span>
          <span class="preset-desc">All 195+ catalogs</span>
        </button>
      </div>

      <div class="divider"></div>

      <!-- Search & controls -->
      <div class="section-title">&#127916; Choose Your Home Screen Rows</div>
      <p style="font-size:11px;color:#888;margin-bottom:14px;letter-spacing:0.03em;">Choose what appears on your Stremio/Nuvio home screen. Too many rows can slow browsing, especially on mobile.</p>
      <div class="info-box" style="margin:0 0 16px 0;">
        <strong>Tip:</strong> 👁 means the row appears on Home. 🙈 means it is hidden from Home but still available in Ultra MAX.
