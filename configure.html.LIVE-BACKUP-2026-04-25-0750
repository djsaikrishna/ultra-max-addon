function setStep(n){
  document.getElementById('step-'+currentStep).classList.remove('active');
  document.getElementById('step-'+n).classList.add('active');
  document.getElementById('counterBar').style.display = n === 2 ? 'flex' : 'none';
  currentStep = n;
  updateProgress();
  window.scrollTo({top:0, behavior:'smooth'});
  setTimeout(makeSprockets, 200);
}

function updateProgress(){
  for(let i=1;i<=4;i++){
    const circle = document.getElementById('circle-'+i);
    const label = document.getElementById('label-'+i);
    circle.className = 'step-circle';
    label.className = 'step-label';
    if(i < currentStep){ circle.classList.add('done'); circle.textContent='✓'; label.classList.add('done'); }
    else if(i === currentStep){ circle.classList.add('active'); circle.textContent=i; label.classList.add('active'); }
    else { circle.textContent=i; }
    if(i < 4){
      const conn = document.getElementById('conn-'+i);
      conn.className = 'step-connector' + (i < currentStep ? ' done' : '');
    }
  }
}

