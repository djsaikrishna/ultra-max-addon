function addCollectionPreset(key){
  const preset = COLLECTION_PRESETS[key];
  if(!preset) return;

  if(collectionDrafts.some(function(c){ return c.key === key; })) return;

  const matches = getCollectionMatches(key);
  if(!matches.length) return;

  collectionDrafts.push({
    key: key,
    title: preset.title,
    cover: '',
    gif: '',
    catalogIds: matches.slice()
  });

  matches.forEach(function(id){
    hidden.add(id);
    const pill = document.querySelector('.pill[data-id="' + id + '"]');
    if(pill){
      pill.style.fontStyle = 'italic';
      const eye = pill.querySelector('.pill-eye');
      if(eye){
        eye.style.display = 'inline';
        eye.textContent = '🙈';
        eye.style.opacity = '1';
      }
    }
  });

  updateCounter();
  updateCategoryCounts();
  refreshCollectionPresetButtons();
  renderCollectionDrafts();
}


function removeCollectionDraft(idx){
  const coll = collectionDrafts[idx];
  if(!coll) return;

  (coll.catalogIds || []).forEach(function(id){
    const stillUsedElsewhere = collectionDrafts.some(function(other, i){
      return i !== idx && (other.catalogIds || []).includes(id);
    });
    if(!stillUsedElsewhere){
      hidden.delete(id);
      const pill = document.querySelector('.pill[data-id="' + id + '"]');
      if(pill){
        pill.style.fontStyle = '';
        const eye = pill.querySelector('.pill-eye');
        if(eye){
          eye.textContent = '👁';
          eye.style.opacity = '0.9';
          eye.style.display = pill.classList.contains('selected') ? 'inline' : 'none';
        }
      }
    }
  });

  collectionDrafts.splice(idx, 1);
  updateCounter();
  updateCategoryCounts();
  refreshCollectionPresetButtons();
  renderCollectionDrafts();
}

function addCollectionRow(idx){
  const sel = document.getElementById('collectionAddSelect-' + idx);
  if(!sel || !sel.value) return;
  const id = sel.value;
  const coll = collectionDrafts[idx];
  if(!coll) return;

  if(!coll.catalogIds.includes(id)){
    coll.catalogIds.push(id);
  }

  hidden.add(id);
  const pill = document.querySelector('.pill[data-id="' + id + '"]');
  if(pill){
    pill.style.fontStyle = 'italic';
    const eye = pill.querySelector('.pill-eye');
    if(eye){
      eye.style.display = 'inline';
      eye.textContent = '🙈';
      eye.style.opacity = '1';
    }
  }

  updateCounter();
  updateCategoryCounts();
  refreshCollectionPresetButtons();
  renderCollectionDrafts();
}

function removeCollectionRow(collIdx, rowIdx){
  const coll = collectionDrafts[collIdx];
  if(!coll) return;

  const id = coll.catalogIds[rowIdx];
  coll.catalogIds.splice(rowIdx, 1);

  const stillUsedElsewhere = collectionDrafts.some(function(other, i){
    return i !== collIdx && (other.catalogIds || []).includes(id);
  });

  if(!stillUsedElsewhere){
    hidden.delete(id);
    const pill = document.querySelector('.pill[data-id="' + id + '"]');
    if(pill){
      pill.style.fontStyle = '';
      const eye = pill.querySelector('.pill-eye');
